#!/system/bin/sh

#
## Added by urain39@cyfan.cf
#

TOPDIR="/data/media/0"
TMPDIRS="$TOPDIR/ramdisk"

[ -f /data/tmpdir.conf ] && TMPDIRS="$(
    sed -E "/^[\t ]*#/d;s:\\\$TOPDIR\\\$?:$TOPDIR:g" /data/tmpdir.conf \
        | grep -Eo '^((/([^/.]{1,2}|[^/.]\.|\.[^/.]|[^/]{3,}))+/?|/)$'
)"

umask 000

IFS=$'\n'
TLEN=${#TOPDIR}
for TMPDIR_ in $TMPDIRS; do
    case "${TMPDIR_:$TLEN:2}" in
    (/?)
        rm -rf "$TMPDIR_" && mkdir -p "$TMPDIR_"
        mount -t tmpfs tmpfs -o "size=25%" "$TMPDIR_" 2> /dev/null
        [ $? != 0 ] && mount -t tmpfs tmpfs "$TMPDIR_"
        ;;
    esac
done
