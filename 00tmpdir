#
## Added by urain39@cyfan.cf
#

TOPDIR="/data/media/0"
TMPDIRS="$TOPDIR/ramdisk"

[ -f /data/tmpdir.conf ] && TMPDIRS="$(sed "/^[\t ]*#/d;s:\\\$TOPDIR:$TOPDIR:g" /data/tmpdir.conf)"

IFS=$'\n'
TLEN=${#TOPDIR}
for TMPDIR_ in $TMPDIRS; do
    echo "$TMPDIR_" | grep -Eq '^([\\\/]([^\\\/\.]{1,2}|[^\\\/]{3,}))*[\\\/]?$'
    if [ $? = 0 ] && [ "${TMPDIR_:0:$TLEN}" == "$TOPDIR" ]; then
        rm -rf "$TMPDIR_" && mkdir -p "$TMPDIR_"
        mount -t tmpfs tmpfs -o "size=25%" "$TMPDIR_" 2> /dev/null
        if [ $? != 0 ]; then
            mount -t tmpfs tmpfs "$TMPDIR_" 2> /dev/null
        fi
    fi
done
